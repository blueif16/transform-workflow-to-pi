{
  "name": "piflow-monorepo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Pi Flow — a self-designing, durable, self-improving orchestration substrate (TypeScript SDK).",
  "license": "MIT",
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b",
    "test": "vitest run --project default",
    "test:watch": "vitest --project default",
    "test:live": "vitest run --project live",
    "test:all": "vitest run",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm run build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@modelcontextprotocol/server-everything": "^2026.1.26",
    "@modelcontextprotocol/server-memory": "^2026.1.26",
    "@types/node": "^24.0.0",
    "openclaw": "^2026.6.9",
    "typescript": "^5.7.0",
    "vitest": "^4.0.0"
  },
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ],
    "overrides": {
      "zod": "^3.25"
    }
  }
}
