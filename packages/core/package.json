{
  "name": "@piflow/core",
  "version": "0.1.0",
  "type": "module",
  "description": "Pi Flow core — the L1 node-envelope schema spine, the DAG compiler (data-flow edge inference), the contract-marker codec, and reference primitives (in-memory sandbox, builtin tool registry, hook runner).",
  "license": "MIT",
  "keywords": [
    "workflow",
    "orchestration",
    "dag",
    "agents",
    "pi",
    "ai",
    "sdk"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/blueif16/PiFlow.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/blueif16/PiFlow/tree/main/packages/core#readme",
  "bugs": "https://github.com/blueif16/PiFlow/issues",
  "author": "blueif16",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./tools/openclaw-shim": {
      "types": "./dist/tools/openclaw-shim.d.ts",
      "import": "./dist/tools/openclaw-shim.js"
    },
    "./seeds/calc": {
      "types": "./dist/seeds/calc.d.ts",
      "import": "./dist/seeds/calc.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -b",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@piflow/tool-bridge": "workspace:*",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "esbuild": "^0.28.1"
  },
  "devDependencies": {
    "zod": "^3.25"
  }
}
