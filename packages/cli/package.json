{
  "name": "@piflow/cli",
  "version": "0.1.0",
  "type": "module",
  "description": "Pi Flow CLI — the docker-style front door to a run. `piflowctl status` (per-node table + stage/rollup) and `piflowctl watch` (a silent-until-it-matters sentinel) read the engine-owned `.pi/` run layout via @piflow/core's path helpers; `logs` is re-exported from core (one front door).",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "cli",
    "workflow",
    "orchestration",
    "pi",
    "agents"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/blueif16/PiFlow.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/blueif16/PiFlow/tree/main/packages/cli#readme",
  "bugs": "https://github.com/blueif16/PiFlow/issues",
  "author": "blueif16",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "piflowctl": "./dist/cli.js"
  },
  "files": [
    "dist",
    "src",
    "skills"
  ],
  "scripts": {
    "build": "tsc -b",
    "prepack": "node scripts/bundle-skills.mjs",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@piflow/core": "workspace:*"
  },
  "optionalDependencies": {
    "@piflow/daytona": "workspace:*",
    "@piflow/e2b": "workspace:*"
  }
}
