{
  "name": "@piflow/langgraph",
  "version": "0.1.0",
  "type": "module",
  "description": "Pi Flow ↔ LangGraph.js connector — ACTIVATE a pi workflow run and GROUND @piflow/core's shared run-status stream (watchRun/RunUpdate — the same one the CLI + TUI render) into a LangGraph graph (streamMode:'custom' via config.writer). Generic: ZERO product/domain vocabulary; the connector only transports run status.",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "langgraph",
    "langchain",
    "workflow",
    "orchestration",
    "pi",
    "agents"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/blueif16/PiFlow.git",
    "directory": "packages/langgraph"
  },
  "homepage": "https://github.com/blueif16/PiFlow/tree/main/packages/langgraph#readme",
  "bugs": "https://github.com/blueif16/PiFlow/issues",
  "author": "blueif16",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -b",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@piflow/core": "workspace:*"
  },
  "peerDependencies": {
    "@langchain/langgraph": ">=0.4 <1",
    "@langchain/core": ">=0.3 <1"
  },
  "devDependencies": {
    "@langchain/langgraph": "^0.4.9",
    "@langchain/core": "^0.3.66"
  }
}
