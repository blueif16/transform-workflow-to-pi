.DS_Store

# Vendored third-party repos for analysis (never committed)
vendor/
vendors/

# JS/TS build + deps (the packages/ SDK)
node_modules/
# worktree-local symlink to the main checkout's gui deps (a symlink isn't a dir, so `node_modules/` misses it)
gui/node_modules
dist/
*.tsbuildinfo

# SVGs untracked for now (illustration library paused). Already-tracked motifs stay tracked.
*.svg

# Session work docs (handoffs/plans) — machine-local, regenerable.
.tasks/

# Scraped design references (e.g. competitor site harvests) — kept local, never committed.
harvest/

# GUI run fixtures: the raw .pi/ telemetry tree is large + regenerable from the source run
# (gui/scripts/transcode-run.mjs). Only the distilled run-view.json is committed.
gui/public/runs/*/.pi/

# `piflow run` from this repo stages per-node prompts/configs into the cwd (transient, regenerable).
/_pi/
/.pi/

# Stale throwaway run output. Real runs live under per-product .piflow/<wf>/runs/ (resolved via
# ~/.piflow/index.json); out/ is scratch and must never be committed.
out/

# piflow example workflows: the template is committed; per-run threads are regenerable.
.piflow/*/runs/

# Claude Code harness artifacts: live git worktrees + session-persisted workflow scripts
# (regenerable, machine-local). Tracked .claude/skills/ stay tracked.
.claude/worktrees/
.claude/workflows/
.tasks/HANDOFF-*.md
