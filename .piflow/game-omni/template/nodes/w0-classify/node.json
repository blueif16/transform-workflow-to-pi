{
  "id": "w0-classify",
  "phase": "classify",
  "deps": [],
  "prompt": {
    "skill": "{{WORKSPACE}}/packages/skills/classify-game/SKILL.md",
    "file": "prompt.md"
  },
  "tools": {
    "allow": [
      "read",
      "ls",
      "grep",
      "find",
      "edit",
      "write",
      "bash",
      "submit_result"
    ],
    "deny": []
  },
  "contract": {
    "artifacts": [
      "spec/classification.json"
    ],
    "owns": [
      "spec/**"
    ],
    "readScope": [
      "{{RUN}}",
      "{{WORKSPACE}}/packages/skills/classify-game",
      "{{WORKSPACE}}/templates/genres.json"
    ],
    "fillSentinel": null
  },
  "policy": {
    "fail": "block"
  },
  "hooks": {
    "promote": [
      {
        "from": "spec/classification.json:archetype",
        "to": "archetype",
        "merge": "set"
      }
    ]
  }
}
