{
  "id": "w4-execute-m2",
  "phase": "execute",
  "deps": [
    "verify-2-m1"
  ],
  "prompt": {
    "skill": "{{WORKSPACE}}/packages/skills/implement-milestone/SKILL.md",
    "file": "prompt.md"
  },
  "tools": {
    "allow": [
      "read",
      "write",
      "edit",
      "bash",
      "submit_result"
    ],
    "deny": []
  },
  "contract": {
    "artifacts": [
      "MEMORY.w4-M2.md"
    ],
    "owns": [
      "src/**",
      "STRUCTURE.md",
      "MEMORY.w4-M2.md"
    ],
    "readScope": [
      "{{RUN}}",
      "{{WORKSPACE}}/packages/skills/implement-milestone",
      "{{WORKSPACE}}/packages/skills/scaffold"
    ],
    "fillSentinel": null
  },
  "policy": {
    "fail": "block"
  },
  "hooks": {
    "merge": {
      "ops": [
        {
          "run": {
            "cmd": "node",
            "args": [
              "{{WORKSPACE}}/templates/registry/check-event-wiring.mjs",
              "--root",
              "{project}",
              "--receipt",
              "{project}/verify/event-wiring.ok.json"
            ],
            "note": "Emit-side event-wiring gate — every declared surface().events name in the generated game (base ∪ W4 custom[]) must have a real .emit() site, else status=blocked."
          }
        }
      ]
    }
  }
}
