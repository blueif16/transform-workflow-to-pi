{
  "id": "gameplay",
  "phase": "gameplay",
  "deps": [
    "w1-design"
  ],
  "prompt": {
    "skill": "{{WORKSPACE}}/packages/skills/harden-blueprint/SKILL.md",
    "file": "prompt.md"
  },
  "tools": {
    "allow": [
      "read",
      "write",
      "edit",
      "submit_result"
    ],
    "deny": []
  },
  "contract": {
    "artifacts": [
      "spec/blueprint.json"
    ],
    "owns": [
      "spec/**"
    ],
    "readScope": [
      "{{RUN}}",
      "{{WORKSPACE}}/templates/genres.json",
      "{{WORKSPACE}}/templates/modules"
    ],
    "fillSentinel": "<FILL:"
  },
  "policy": {
    "fail": "block"
  },
  "hooks": {
    "seed": [
      {
        "to": "spec/blueprint.json",
        "from": "{{WORKSPACE}}/templates/modules/{{state.archetype}}/blueprint.template.json"
      }
    ],
    "merge": {
      "ops": [
        {
          "run": {
            "cmd": "node",
            "args": [
              "{{WORKSPACE}}/packages/skills/harden-blueprint/gen/seed-contracts.mjs",
              "--source",
              "{project}/spec/blueprint.json",
              "--catalog",
              "{{WORKSPACE}}/.agents/node-catalog.json"
            ],
            "note": "Consumer-side contract derivation: seed blueprint.contracts.<node> from the node-catalog (relocated out of core)."
          }
        }
      ]
    }
  }
}
