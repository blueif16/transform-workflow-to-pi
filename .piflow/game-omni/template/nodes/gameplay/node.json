{
  "id": "gameplay",
  "phase": "gameplay",
  "deps": [
    "w1-design"
  ],
  "prompt": {
    "skill": "{{WORKSPACE}}/packages/skills/harden-blueprint/SKILL.md",
    "file": "prompt.md"
  },
  "tools": {
    "allow": [
      "read",
      "write",
      "edit",
      "submit_result"
    ],
    "deny": []
  },
  "contract": {
    "artifacts": [
      "spec/blueprint.json"
    ],
    "owns": [
      "spec/**"
    ],
    "readScope": [
      "{{RUN}}",
      "{{WORKSPACE}}/templates/genres.json",
      "{{WORKSPACE}}/templates/modules"
    ],
    "fillSentinel": "<FILL:"
  },
  "policy": {
    "fail": "block"
  },
  "hooks": {
    "seed": [
      {
        "to": "spec/blueprint.json",
        "from": "{{WORKSPACE}}/templates/modules/{{state.archetype}}/blueprint.template.json"
      }
    ],
    "seedContracts": {
      "source": "spec/blueprint.json",
      "catalog": "{{WORKSPACE}}/.agents/node-catalog.json"
    }
  }
}
