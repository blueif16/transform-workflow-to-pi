{
  "id": "build",
  "phase": "build",
  "deps": [
    "verify-join"
  ],
  "prompt": {
    "file": "prompt.md",
    "skill": "test-discipline"
  },
  "agentType": "coder",
  "tools": {
    "allow": [
      "read",
      "write",
      "edit",
      "bash",
      "submit_result"
    ]
  },
  "contract": {
    "artifacts": [
      "out/module.md"
    ],
    "owns": [
      "out/**"
    ],
    "readScope": [
      "{{RUN}}/frag"
    ]
  },
  "policy": {
    "fail": "block"
  }
}
