# pi-runner config — COPY to pi-runner/.env and fill in. NEVER commit the real .env.
# This file is the ONLY per-repo surface: run.mjs / extract.mjs / providers/coding-plan.ts are
# byte-identical across every repo (and the global-skill template), so a fix to one is a one-file
# copy. Everything project-specific lives here.

# ── Wiring (point the generic driver at THIS repo's workflow) ──────────────────────────────
# PI_RUNNER_ROOT defaults to pi-runner/'s parent dir — usually correct, leave unset.
# PI_RUNNER_CWD + PI_RUNNER_WORKFLOW take paths RELATIVE TO ROOT (or absolute).
PI_RUNNER_CWD=.                                    # where pi runs (npm-scripts dir); e.g. a subpackage
PI_RUNNER_WORKFLOW=.claude/workflows/CHANGEME.js   # the workflow .js this repo drives
# PI_RUNNER_UNTIL=design                           # optional default --until during bring-up
# PI_RUNNER_NODE_TIMEOUT=1800                       # optional default node hard-kill seconds (--node-timeout overrides; raise for long build/render nodes)
# PI_RUNNER_REPEAT_KILL=400                          # stuck-loop guard: kill a node after N consecutive identical deltas (0 disables; legit nodes never exceed ~2)

# ── Model / credential (any OpenAI-compatible coding-plan endpoint) ────────────────────────
# Saved as DEFAULTS so the model/key are set ONCE, not per-run.
CODING_PLAN_API_KEY=sk-REPLACE_ME
PI_CP_BASE_URL=https://your-provider.example.com/compatible-mode/v1
PI_CP_MODELS=primary-model-id,secondary-model-id
PI_CP_MODEL=primary-model-id
PI_CP_NAME=Coding Plan
# thinking OFF is faster/cheaper while shaking out mechanics; flip to 1 for highest quality.
PI_CP_REASONING=0
PI_CP_CONTEXT=131072
PI_CP_MAXTOKENS=8192
